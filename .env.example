# .env.example

# Supabase
DATABASE_URL=postgresql+psycopg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=

# ntfy push notifications
NTFY_TOPIC=

# Backup destination (optional)
# Absolute path to the backup folder. Supports WSL paths to Windows/OneDrive.
# If not set, backup is written to the current directory.
# Example: /mnt/c/Users/Pierre/OneDrive/plantiq/backups
BACKUP_PATH=
